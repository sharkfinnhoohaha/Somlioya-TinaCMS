# TinaCMS Configuration
# For Tina Cloud (optional - enables cloud-based editing and branching)
# Sign up at https://app.tina.io to get these values
NEXT_PUBLIC_TINA_CLIENT_ID=
TINA_TOKEN=

# GitHub branch for Tina Cloud content sync (optional)
GITHUB_BRANCH=main

# Google Maps API key (used for 3D map feature - unchanged from Sanity version)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
