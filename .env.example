# ─────────────────────────────────────────────────────────────────────────────
# Environment variables for the Sømliøya site.
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is git-ignored — never commit real secrets.
# On Vercel, set these in Project Settings → Environment Variables instead.
# ─────────────────────────────────────────────────────────────────────────────

# TinaCMS — from your project at https://app.tina.io
# NEXT_PUBLIC_TINA_CLIENT_ID is public (sent to the browser).
# TINA_TOKEN is a SECRET read/write token — keep it private.
NEXT_PUBLIC_TINA_CLIENT_ID=your-tina-client-id
TINA_TOKEN=your-tina-read-write-token

# Google Maps Platform API key — used by the 3D map and the region map.
# Requires the "Map Tiles API" and "Maps Static API" enabled.
# This key is sent to the browser, so restrict it by HTTP referrer
# (your production domain) in the Google Cloud Console.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
